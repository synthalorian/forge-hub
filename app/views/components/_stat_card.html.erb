<%
  hover_border ||= "hover:border-neon-purple/30"
  tag_name = local_assigns[:href] ? :a : :div
  href_attr = local_assigns[:href] ? { href: href } : {}
%>

<%= content_tag tag_name, href_attr,
    class: "rounded-xl bg-bg-panel/80 border border-border-faint p-5 #{hover_border}
            hover:shadow-lg hover:shadow-neon-purple/5 transition-all duration-200 block backdrop-blur-sm" do %>
  <div class="flex items-center gap-3">
    <% if local_assigns[:icon] %>
      <span class="<%= icon_color %> text-2xl drop-shadow-[0_0_8px_currentColor]"><%= icon %></span>
    <% end %>
    <div>
      <p class="text-2xl font-bold font-mono text-text-primary"><%= value %></p>
      <p class="text-xs text-text-muted uppercase tracking-wider mt-0.5 font-mono"><%= label %></p>
    </div>
  </div>
<% end %>
