<div class="flex flex-col items-center justify-center py-16 px-6 text-center">
  <span class="text-4xl text-text-dim mb-4"><%= local_assigns[:icon] || "◈" %></span>

  <h3 class="text-lg font-semibold text-text-primary mb-1"><%= local_assigns[:message] %></h3>

  <% if local_assigns[:description] %>
    <p class="text-sm text-text-muted max-w-md"><%= local_assigns[:description] %></p>
  <% end %>

  <% if local_assigns[:action_text] && local_assigns[:action_path] %>
    <div class="mt-6">
      <a href="<%= local_assigns[:action_path] %>"
         class="inline-flex items-center gap-2 px-4 py-2 rounded-lg
                bg-neon-cyan/10 text-neon-cyan border border-neon-cyan/30
                hover:bg-neon-cyan/20 transition-colors text-sm font-medium">
        <%= local_assigns[:action_text] %>
      </a>
    </div>
  <% end %>
</div>
