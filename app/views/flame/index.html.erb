<% content_for :breadcrumb do %>
  <span class="text-text-primary">Flame</span>
<% end %>

<div class="space-y-6 max-w-6xl">
  <div>
    <h1 class="text-2xl font-bold text-neon-hot-pink font-mono tracking-tight">FLAME</h1>
    <p class="text-text-muted text-sm mt-1">Scripture & spirit — the fire that tempers the steel</p>
  </div>

  <!-- Stats Row -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <%= render "components/stat_card",
        label: "Bible Verses",
        value: "31,103",
        icon: "📖",
        icon_color: "text-neon-hot-pink" %>
    <%= render "components/stat_card",
        label: "Translation",
        value: "KJV",
        icon: "✦",
        icon_color: "text-neon-purple" %>
    <%= render "components/stat_card",
        label: "Journal Entries",
        value: @journal_count,
        icon: "📝",
        icon_color: "text-neon-cyan" %>
  </div>

  <!-- Daily Verse -->
  <div class="rounded-xl bg-bg-panel border border-neon-hot-pink/20 p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-neon-hot-pink text-xl">📖</span>
      <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider">Today's Verse</h3>
    </div>
    <% if @daily_verse.present? %>
      <pre class="text-sm text-neon-cyan/90 font-mono whitespace-pre-wrap leading-relaxed"><%= @daily_verse %></pre>
    <% else %>
      <p class="text-text-muted text-sm">Run <code class="text-neon-cyan font-mono">forge word</code> to see today's verse.</p>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <!-- Scripture Commands -->
    <div class="rounded-xl bg-bg-panel border border-border-subtle/20 p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">📖 Scripture</h3>
      <div class="space-y-2">
        <% scripture_cmds = [
          { cmd: "forge word", desc: "Today's verse" },
          { cmd: "forge word search <query>", desc: "Full-text search" },
          { cmd: "forge word reference John 3:16", desc: "Passage lookup" },
          { cmd: "forge word search \"For God so loved\"", desc: "Search by phrase" }
        ] %>
        <% scripture_cmds.each do |cmd| %>
          <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-subtle/10">
            <code class="text-xs text-neon-cyan font-mono"><%= cmd[:cmd] %></code>
            <p class="text-xs text-text-muted mt-1"><%= cmd[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Journal Commands -->
    <div class="rounded-xl bg-bg-panel border border-border-subtle/20 p-5">
      <h3 class="text-sm font-semibold text-text-primary mb-4 uppercase tracking-wider">📝 Prayer Journal</h3>
      <div class="space-y-2">
        <% journal_cmds = [
          { cmd: "forge reflect entry \"Today I...\"", desc: "Write an entry" },
          { cmd: "forge reflect history", desc: "Browse entries" },
          { cmd: "forge reflect read <id>", desc: "Read specific entry" },
          { cmd: "forge reflect search <query>", desc: "Search entries" }
        ] %>
        <% journal_cmds.each do |cmd| %>
          <div class="bg-bg-surface/30 rounded-lg p-3 border border-border-subtle/10">
            <code class="text-xs text-neon-purple font-mono"><%= cmd[:cmd] %></code>
            <p class="text-xs text-text-muted mt-1"><%= cmd[:desc] %></p>
          </div>
        <% end %>
      </div>
      <div class="mt-4 p-3 rounded-lg bg-bg-surface/30 border border-border-subtle/10">
        <div class="flex items-center gap-2">
          <span class="text-xs text-neon-yellow">🔒</span>
          <span class="text-xs text-text-muted">AES-256-GCM encrypted at rest</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Sabbath Mode -->
  <div class="rounded-xl bg-bg-panel border border-neon-purple/20 p-5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-neon-purple text-xl">🕯️</span>
        <div>
          <h3 class="text-sm font-semibold text-text-primary">Sabbath Mode</h3>
          <p class="text-xs text-text-muted mt-0.5">Shut down all agents and find rest</p>
        </div>
      </div>
      <code class="text-xs text-neon-cyan font-mono bg-bg-surface/50 px-3 py-1.5 rounded">forge rest</code>
    </div>
  </div>
</div>
