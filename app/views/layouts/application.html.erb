<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <title><%= content_for(:title) || @title || "Forge Hub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Forge Hub">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="preconnect" href="https://fonts.bunny.net">
    <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700|jetbrains-mono:400,500" rel="stylesheet">
  </head>

  <body class="bg-bg-dark text-text-primary font-sans antialiased min-h-screen overflow-x-hidden">
    <div class="horizon-glow"></div>

    <div data-controller="sidebar" class="flex min-h-screen relative" style="z-index: 1;">
      <%= render "layouts/sidebar" %>

      <!-- Main content area -->
      <div class="flex-1 flex flex-col min-w-0 transition-all duration-300">
        <%= render "layouts/topbar" %>

        <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
          <% if notice || alert %>
            <div class="mb-6 space-y-2">
              <% if notice %>
                <div class="bg-neon-green/10 border border-neon-green/30 text-neon-green rounded-lg px-4 py-3 font-mono text-sm" role="alert">
                  <%= notice %>
                </div>
              <% end %>
              <% if alert %>
                <div class="bg-neon-red/10 border border-neon-red/30 text-neon-red rounded-lg px-4 py-3 font-mono text-sm" role="alert">
                  <%= alert %>
                </div>
              <% end %>
            </div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
