<% content_for :breadcrumb do %>
  <%= link_to "Anvil", "/anvil", class: "hover:text-neon-cyan transition-colors" %>
  <span class="text-text-dim">/</span>
  <span class="text-text-primary">Schedules</span>
<% end %>

<div class="space-y-6 max-w-4xl">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-neon-cyan font-mono tracking-tight">SCHEDULES</h1>
      <p class="text-text-muted text-sm mt-1">Automated backup schedules configured via forge CLI</p>
    </div>
    <%= link_to anvil_backups_path,
        class: "px-4 py-2 rounded-lg bg-bg-panel border border-border-faint
                text-text-muted hover:text-text-primary hover:border-border-subtle/40
                transition-colors text-sm font-medium" do %>
      Backups
    <% end %>
  </div>

  <div class="rounded-xl bg-bg-panel border border-border-faint p-5">
    <h2 class="text-sm font-semibold text-text-primary mb-3">Add Schedule</h2>
    <%= form_with url: anvil_schedules_path, method: :post, class: "flex flex-col sm:flex-row gap-3" do |f| %>
      <div class="flex-1">
        <%= text_field_tag :cron_expression, nil,
            placeholder: "0 2 * * *",
            class: "w-full px-3 py-2 rounded-lg bg-bg-dark border border-border-faint
                    text-text-primary text-sm font-mono placeholder:text-text-dim
                    focus:border-neon-cyan/50 focus:outline-none transition-colors" %>
      </div>
      <div class="flex-1">
        <%= text_field_tag :target_path, nil,
            placeholder: "/path/to/repo",
            class: "w-full px-3 py-2 rounded-lg bg-bg-dark border border-border-faint
                    text-text-primary text-sm font-mono placeholder:text-text-dim
                    focus:border-neon-cyan/50 focus:outline-none transition-colors" %>
      </div>
      <%= submit_tag "Add",
          class: "px-4 py-2 rounded-lg bg-neon-cyan/20 border border-neon-cyan/40
                  text-neon-cyan hover:bg-neon-cyan/30 transition-colors text-sm font-medium cursor-pointer" %>
    <% end %>
  </div>

  <% if @schedules.any? %>
    <div class="space-y-3">
      <% @schedules.each do |schedule| %>
        <div class="rounded-xl bg-bg-panel border border-border-faint p-4
                    hover:border-neon-cyan/30 transition-all duration-200">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4 min-w-0">
              <span class="<%= schedule[:enabled] ? 'text-neon-cyan' : 'text-text-dim' %> text-lg shrink-0">⏰</span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-text-primary truncate">
                  <%= schedule[:target_path] %>
                </p>
                <div class="flex items-center gap-3 mt-1">
                  <code class="text-xs font-mono text-neon-purple bg-bg-dark/50 px-2 py-0.5 rounded">
                    <%= schedule[:cron_expression] %>
                  </code>
                  <span class="inline-flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full <%= schedule[:enabled] ? 'bg-neon-cyan' : 'bg-text-dim' %>"></span>
                    <span class="text-xs text-text-muted"><%= schedule[:enabled] ? "Enabled" : "Disabled" %></span>
                  </span>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-3 shrink-0 ml-4">
              <div class="text-right">
                <p class="text-xs text-text-muted">
                  <% if schedule[:last_run] %>
                    Last run: <%= time_ago(schedule[:last_run]) %>
                  <% else %>
                    Never run
                  <% end %>
                </p>
                <p class="text-[10px] text-text-dim mt-0.5">
                  Created <%= time_ago(schedule[:created_at]) %>
                </p>
              </div>
              <%= button_to "Remove", anvil_schedule_path(schedule[:id]),
                  method: :delete,
                  data: { turbo_confirm: "Remove this schedule?" },
                  class: "px-3 py-1.5 rounded-lg bg-neon-red/10 border border-neon-red/30
                          text-neon-red hover:bg-neon-red/20 transition-colors text-xs font-medium cursor-pointer" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "components/empty_state",
      icon: "⏰",
      message: "No schedules configured",
      description: "Use `forge schedule add \"0 2 * * *\" /path/to/repo` in your terminal to set up automated backups." %>
  <% end %>
</div>
